# Clerk (get from https://dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Use production API instead of localStorage (set to "true" when deployed)
# Leave unset or "false" for local dev with localStorage
# VITE_USE_API=true

# API base URL — set when developing locally with VITE_USE_API=true.
# Use your Cloudflare Pages URL (e.g. https://your-project.pages.dev) so API calls hit the deployed backend.
# VITE_API_BASE=
